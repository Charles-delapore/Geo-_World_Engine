RUN_MODE=celery
ARTIFACT_BACKEND=s3
DATABASE_URL=postgresql+psycopg://mapuser:mappass@postgres:5432/mapdb
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=geo-world-beta
MINIO_USE_SSL=false
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
ENABLE_RAG=true
RECIPE_DB_URL=sqlite:///./backend/data/recipes.db
RAG_MIN_SIMILARITY=0.50
RAG_SECOND_DIFF_THRESHOLD=0.10
RAG_TOP_K=2
RAG_LOG_LEVEL=INFO
